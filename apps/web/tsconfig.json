{
  "extends": "@workspace/tsconfig/nextjs.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@locales/*": ["public/locales/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.config.ts",
    "playwright.config.ts",
    "playwright.visual.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
