{
  "name": "phungdao-aepsy-react-takehome",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:visual": "pnpm --filter @workspace/web test:visual",
    "test:visual:update": "pnpm --filter @workspace/web test:visual:update",
    "format": "prettier --cache --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.15",
    "prettier": "3.8.3",
    "turbo": "2.9.6",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
